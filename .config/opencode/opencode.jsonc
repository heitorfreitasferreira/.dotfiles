{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "codegraphcontext": {
      "type": "local",
      "command": [
        "cgc",
        "mcp",
        "start"
      ],
      "enabled": true,
      "timeout": 15000
    }
  },
  "agent": {
    "django-pattern-router": {
      "description": "Route Django requests to the right domain and suggest idiomatic patterns.",
      "mode": "subagent",
      "tools": {
        "bash": false,
        "write": false,
        "edit": false
      },
      "prompt": "{file:./prompts/django-pattern-router.prompt.md}"
    },
    "sherlock": {
      "description": "Investigate errors deeply and produce a root-cause debugging report.",
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "task": false,
        "todowrite": false,
        "todoread": false
      },
      "prompt": "{file:./prompts/sherlock.prompt.md}"
    }
  }
}
